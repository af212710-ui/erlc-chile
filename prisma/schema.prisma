generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  discordId     String?   @unique
  discordUsername String?
  role          String    @default("civil")

  run           String?   @unique
  fullName      String?
  apellidoPaterno String?
  apellidoMaterno String?
  edad          Int?
  genero        String?
  direccion     String?
  foto          String?

  bancoCuenta   String?   @unique @default(cuid())
  saldo         Decimal   @default(5000.00)

  tarjetaNumero     String?   @unique
  tarjetaVencimiento String?
  tarjetaCVV        String?
  tarjetaTipo       String?   @default("Débito")

  licenciaConducir     Boolean @default(false)
  licenciaConducirNum  String?
  licenciaArmas        Boolean @default(false)
  licenciaArmasNum     String?

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Vehicle {
  id          String   @id @default(cuid())
  placa       String   @unique
  modelo      String
  marca       String
  color       String
  propietarioRun String
  propietario User     @relation(fields: [propietarioRun], references: [run])

  createdAt   DateTime @default(now())
}

model PoliceAccessLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  targetRun String?
  targetPlaca String?
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
